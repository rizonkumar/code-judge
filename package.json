{
  "name": "code-judge",
  "version": "1.0.0",
  "description": "A full-stack code evaluation platform - LeetCode-like coding judge",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=server && npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "build:client": "npm run build --workspace=client"
  },
  "keywords": [
    "code-judge",
    "leetcode",
    "evaluator",
    "coding-platform"
  ],
  "author": "Rizon Kumar Rahi",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
